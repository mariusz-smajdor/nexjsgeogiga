{
	"extends": "@geogiga/typescript-config/base-config",
	"compilerOptions": {
		"paths": {
			"@/*": ["./src/*"]
		},
		"tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
		"target": "es2023",
		"lib": ["ES2023", "DOM", "DOM.Iterable"],
		"module": "esnext",
		"types": ["vite/client"],
		"skipLibCheck": true,

		/* Bundler mode */
		"moduleDetection": "force",
		"allowImportingTsExtensions": true,
		"noEmit": true,
		"jsx": "react-jsx",

		/* Linting */
		"erasableSyntaxOnly": true
	},
	"include": ["src"]
}
